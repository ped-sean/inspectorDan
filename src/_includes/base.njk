<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <meta name="theme-color" content="#f57c00">

    {#- Favicons -#}
    <link rel="icon" type="image/webp" href="/images/logo.webp">
    <link rel="apple-touch-icon" href="/images/logo.webp">

    {#- Canonical + social previews -#}
    {%- set siteUrl = "https://inspectordan.net" -%}
    {%- set pagePath = page.url if page and page.url else "/" -%}
    <link rel="canonical" href="{{ siteUrl }}{{ pagePath }}">

    <meta property="og:site_name" content="InspectorDan LLC">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:url" content="{{ siteUrl }}{{ pagePath }}">
    <meta property="og:image" content="{{ siteUrl }}/images/logo.webp">

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="{{ siteUrl }}/images/logo.webp">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&family=Sora:wght@600;700&display=swap">
    <link rel="stylesheet" href="styles.css">

    {#- Structured data: LocalBusiness for Google Maps / rich results -#}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "HomeAndConstructionBusiness",
        "name": "InspectorDan LLC",
        "image": "{{ siteUrl }}/images/logo.webp",
        "url": "{{ siteUrl }}",
        "telephone": "+1-773-771-6466",
        "email": "inspectordan@gmail.com",
        "priceRange": "$$",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Westchester",
            "addressRegion": "IL",
            "addressCountry": "US"
        },
        "areaServed": [
            { "@type": "City", "name": "Chicago" },
            { "@type": "AdministrativeArea", "name": "Greater Chicago area" }
        ],
        "founder": { "@type": "Person", "name": "Daniel Cullen" },
        "hasCredential": "Certified Professional Inspector (CPI®) — InterNACHI"
    }
    </script>
</head>
<body>
    <a href="#main" class="skip-link">Skip to content</a>

    {#- The header/nav lives here ONLY. Edit once; every page updates. -#}
    <header class="site-header">
        <div class="wrap header-inner">
            <a href="index.html" class="brand" aria-label="InspectorDan home">
                <img class="brand-logo" src="images/logo.webp" alt="InspectorDan — home inspections" width="189" height="92" fetchpriority="high" decoding="async">
            </a>
            <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav">
                <span></span><span></span><span></span>
            </button>
            <nav id="nav" class="nav">
                {%- set navItems = [
                    { url: "index.html", label: "Home", key: "home" },
                    { url: "services.html", label: "Services", key: "services" },
                    { url: "referrals.html", label: "Referrals", key: "referrals" },
                    { url: "blog.html", label: "Blog", key: "blog" }
                ] -%}
                {%- for item in navItems %}
                <a href="{{ item.url }}"{% if active == item.key %} class="active"{% endif %}>{{ item.label }}</a>
                {%- endfor %}
                <!-- EXTERNAL LINK (booking) — HomeGauge ScheduleNow. See INTEGRATION-NOTES.md #1. -->
                <a href="https://schedulenow.homegauge.com/11ecebf8-c830-7b99-af04-77c0e9971dab/schedule" class="nav-cta" data-external="schedule" target="_blank" rel="noopener">Book Now</a>
            </nav>
        </div>
    </header>

    <main id="main">
        {{ content | safe }}
    </main>

    {#- The footer lives here ONLY. -#}
    <footer class="site-footer">
        <div class="wrap footer-inner">
            <div>
                <a href="index.html" class="brand" aria-label="InspectorDan home">
                    <img class="footer-logo" src="images/logo.webp" alt="InspectorDan — home inspections" width="189" height="92" loading="lazy" decoding="async">
                </a>
                <p>Home, commercial &amp; new-construction inspections serving Westchester and the greater Chicago area.</p>
            </div>
            <nav class="footer-links" aria-label="Footer">
                <a href="services.html">Services</a>
                <a href="referrals.html">Referrals</a>
                <a href="blog.html">Blog</a>
                <!-- EXTERNAL DOCUMENT (Google Drive PDF) — see INTEGRATION-NOTES.md #4. -->
                <a href="https://drive.google.com/file/d/1SZl1VHj6Nne5dlst_AArIiMVNMm-kAN8/view?usp=sharing" data-external="document" target="_blank" rel="noopener">Consumer-Contractor Cautions</a>
                <a href="images/logo.webp" download="InspectorDan-logo.webp">Download logo</a>
            </nav>
            <div class="footer-contact">
                <!-- EXTERNAL LINK (booking) — HomeGauge ScheduleNow. See INTEGRATION-NOTES.md #1. -->
                <a href="https://schedulenow.homegauge.com/11ecebf8-c830-7b99-af04-77c0e9971dab/schedule" data-external="schedule" target="_blank" rel="noopener">Book an Inspection</a>
                <a href="tel:+17737716466">773-771-6466</a>
                <a href="mailto:inspectordan@gmail.com">inspectordan@gmail.com</a>
                <span>Westchester, IL</span>
            </div>
        </div>
        <p class="copyright">© 2025 InspectorDan LLC · Certified Professional Inspector®</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
