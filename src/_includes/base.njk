<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&family=Sora:wght@600;700&display=swap">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <a href="#main" class="skip-link">Skip to content</a>

    {#- The header/nav lives here ONLY. Edit once; every page updates. -#}
    <header class="site-header">
        <div class="wrap header-inner">
            <a href="index.html" class="brand" aria-label="InspectorDan home">
                <img class="brand-logo" src="images/logo.webp" alt="InspectorDan — home inspections">
            </a>
            <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav">
                <span></span><span></span><span></span>
            </button>
            <nav id="nav" class="nav">
                {%- set navItems = [
                    { url: "index.html", label: "Home", key: "home" },
                    { url: "services.html", label: "Services", key: "services" },
                    { url: "referrals.html", label: "Referrals", key: "referrals" },
                    { url: "blog.html", label: "Blog", key: "blog" }
                ] -%}
                {%- for item in navItems %}
                <a href="{{ item.url }}"{% if active == item.key %} class="active"{% endif %}>{{ item.label }}</a>
                {%- endfor %}
                <!-- EXTERNAL LINK (booking) — HomeGauge ScheduleNow. See INTEGRATION-NOTES.md #1. -->
                <a href="https://schedulenow.homegauge.com/11ecebf8-c830-7b99-af04-77c0e9971dab/schedule" class="nav-cta" data-external="schedule" target="_blank" rel="noopener">Book Now</a>
            </nav>
        </div>
    </header>

    <main id="main">
        {{ content | safe }}
    </main>

    {#- The footer lives here ONLY. -#}
    <footer class="site-footer">
        <div class="wrap footer-inner">
            <div>
                <a href="index.html" class="brand" aria-label="InspectorDan home">
                    <img class="footer-logo" src="images/logo.webp" alt="InspectorDan — home inspections">
                </a>
                <p>Home, commercial &amp; new-construction inspections serving Westchester and the greater Chicago area.</p>
            </div>
            <nav class="footer-links" aria-label="Footer">
                <a href="services.html">Services</a>
                <a href="referrals.html">Referrals</a>
                <a href="blog.html">Blog</a>
                <!-- EXTERNAL DOCUMENT (Google Drive PDF) — see INTEGRATION-NOTES.md #4. -->
                <a href="https://drive.google.com/file/d/1SZl1VHj6Nne5dlst_AArIiMVNMm-kAN8/view?usp=sharing" data-external="document" target="_blank" rel="noopener">Consumer-Contractor Cautions</a>
            </nav>
            <div class="footer-contact">
                <!-- EXTERNAL LINK (booking) — HomeGauge ScheduleNow. See INTEGRATION-NOTES.md #1. -->
                <a href="https://schedulenow.homegauge.com/11ecebf8-c830-7b99-af04-77c0e9971dab/schedule" data-external="schedule" target="_blank" rel="noopener">Book an Inspection</a>
                <a href="tel:+17737716466">773-771-6466</a>
                <a href="mailto:inspectordan@gmail.com">inspectordan@gmail.com</a>
                <span>Westchester, IL</span>
            </div>
        </div>
        <p class="copyright">© 2025 InspectorDan LLC · Certified Professional Inspector®</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
